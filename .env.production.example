# .env.production.example
# Copy this to /opt/unicorns-edu/.env on the VPS and fill in all values.
# NEVER commit the actual .env file.
#
# GitHub Actions (build web image): CI builds with NEXT_PUBLIC_BACKEND_URL=/api so
# IT and ENG share one web image (browser calls same-origin /api per domain).

# ── Database (Managed PostgreSQL) ────────────────────────────────────────────
# DATABASE_URL: Supavisor transaction pooler for API runtime (Supabase :6543?pgbouncer=true).
DATABASE_URL="postgresql://postgres.PROJECT_REF:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL: Supavisor session mode for migrate deploy — same host/user as DATABASE_URL, port 5432, no pgbouncer=true.
# Do NOT use db.PROJECT_REF.supabase.co here (IPv6-only; VPS/CD often fails with P1001).
DIRECT_URL="postgresql://postgres.PROJECT_REF:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── App URLs ─────────────────────────────────────────────────────────────────
PORT=4000
# Public API prefix qua cloudflared -> local Nginx (strip /api -> backend).
# Khớp NEXT_PUBLIC_BACKEND_URL khi build web.
# FRONTEND_URL must be the exact public HTTPS browser origin, without trailing slash.
# Direct top-up approval emails are rejected in production if this is localhost or non-HTTPS.
BACKEND_URL="https://YOUR_CLOUDFLARE_HOSTNAME/api"
FRONTEND_URL="https://YOUR_CLOUDFLARE_HOSTNAME"

# ── Reverse proxy ────────────────────────────────────────────────────────────
# Must be 1 when running behind Nginx so throttler sees real client IPs
TRUST_PROXY=1
# Do not set NODE_ENV in the VPS .env. docker-compose.prod.yml pins production
# so auth cookies always use the production policy.

# ── JWT Secrets (generate with: openssl rand -base64 64) ─────────────────────
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EMAIL_VERIFY_SECRET=""
JWT_FORGOT_PASSWORD_SECRET=""

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Receives approval links for staff-created student wallet direct top-up requests.
# Must be a real deliverable mailbox; placeholders like admin@example.com are rejected.
ADMIN_EMAIL="admin@unicornsedu.com"
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE=false
MAIL_FROM="no-reply@unicornsedu.com"

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://YOUR_CLOUDFLARE_HOSTNAME/api/auth/google/callback"

# ── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_DEFAULT_LIMIT=300
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_BLOCK_DURATION_MS=60000

# ── Caching ──────────────────────────────────────────────────────────────────
DASHBOARD_CACHE_DEFAULT_TTL_SECONDS=60
AUTH_IDENTITY_CACHE_TTL_MS=5000
AUTH_IDENTITY_CACHE_MAX_ENTRIES=2000

# ── Docker Compose (multi-instance VPS) ─────────────────────────────────────
COMPOSE_PROJECT_NAME=unicorns-it
NGINX_PUBLISH=127.0.0.1:80:80

# ── SePay student wallet top-up ──────────────────────────────────────────────
# For MBBank/non-VA banks, use bank_transfer and configure VietQR account info.
SEPAY_TOPUP_MODE="bank_transfer"
# VA-order mode only: SePay UserAPI v2 credentials.
SEPAY_API_ACCESS_TOKEN=""
SEPAY_BANK_ACCOUNT_XID=""
# Bank-transfer mode: receiver account used to generate VietQR links.
SEPAY_TRANSFER_BANK_BIN="970422"
SEPAY_TRANSFER_ACCOUNT_NUMBER=""
SEPAY_TRANSFER_ACCOUNT_NAME=""
SEPAY_TRANSFER_BANK_NAME="MBBank"
SEPAY_TRANSFER_QR_TEMPLATE="compact2"
SEPAY_VIETQR_IMAGE_BASE_URL="https://img.vietqr.io/image"
# Webhook URL behind the current Nginx /api prefix: https://it.unicornsedu.com/api/webhook/sepay
# HMAC signs X-SePay-Timestamp + "." + the exact raw JSON body bytes from SePay.
SEPAY_WEBHOOK_SECRET=""
SEPAY_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
# Set to 1 only while SePay is still sending the documented legacy X-Secret-Key header.
SEPAY_WEBHOOK_ALLOW_LEGACY_SECRET_KEY=0
