# Sao chép thành `apps/web/.env` khi chạy local. Next.js chỉ nạp biến bắt đầu bằng NEXT_PUBLIC_ vào bundle client.

NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Bật luồng nạp dương qua SePay (QR do backend tạo theo SEPAY_TOPUP_MODE). Cần cấu hình SEPAY_* trên `apps/api`.
# Khi bật, số dương phải >= 1.000 VND; webhook ngân hàng cập nhật ví tự động sau xác nhận.
# Nếu API đã cấu hình SePay top-up, nên bật cờ này;
# backend sẽ chặn self-service nạp dương qua PATCH để tránh bypass luồng SePay.
NEXT_PUBLIC_STUDENT_WALLET_SEPAY_TOPUP=0
