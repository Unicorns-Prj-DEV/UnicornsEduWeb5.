# Sao chép thành `apps/web/.env` khi chạy local. Next.js chỉ nạp biến bắt đầu bằng NEXT_PUBLIC_ vào bundle client.

NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Bật luồng nạp dương qua SePay (QR do backend gọi SePay). Cần cấu hình SEPAY_* trên `apps/api`.
# Khi không bật (=0 hoặc không set), nạp số dương vẫn dùng PATCH điều chỉnh số dư trực tiếp như cũ.
NEXT_PUBLIC_STUDENT_WALLET_SEPAY_TOPUP=0
