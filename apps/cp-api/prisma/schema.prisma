// Unicorns Edu - Refined Database Schema (Prisma)
// Migrated and refined from archived Supabase schema
// Use PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../generated/"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================
enum UserRole {
  admin
  teacher
  student
  assistant
  visitor
}

enum UserStatus {
  active
  inactive
  pending
}

enum AssistantType {
  technical
  lesson_plan
}

enum ClassStatus {
  running
  paused
  ended
}

enum ClassTeacherStatus {
  active
  inactive
}

enum StudentStatus {
  active
  inactive
}

enum Gender {
  male
  female
}

enum SessionPaymentStatus {
  paid
  unpaid
  deposit
}

enum PaymentStatus {
  paid
  pending
  cancelled
}

enum WalletTransactionType {
  topup
  loan
  advance
  repayment
}

enum DashboardCacheType {
  dashboard
  quickview
}

enum HomePostCategory {
  intro
  news
  docs
  policy
}

enum LessonPlanType {
  resource
  completed_task
}

enum LessonTaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum LessonTaskPriority {
  low
  medium
  high
}

// ============================================
// USERS (Authentication & Authorization)
// ============================================
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String?
  passwordHash      String    @map("password_hash") // Consolidated: use argon2/bcrypt hash only
  name              String?
  role              UserRole
  province          String?
  status            UserStatus @default(active)
  accountHandle     String?   @unique @map("account_handle")
  assistantType     AssistantType? @map("assistant_type")
  emailVerified     Boolean   @default(false) @map("email_verified")
  phoneVerified     Boolean   @default(false) @map("phone_verified")
  resetToken        String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Optional link to profile (one user links to one profile)
  teacherId   String?  @unique @map("teacher_id")
  teacher     Teacher? @relation("UserTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  studentId   String?  @unique @map("student_id")
  student     Student? @relation("UserStudent", fields: [studentId], references: [id], onDelete: SetNull)
  assistantId String?  @unique @map("assistant_id")
  assistant   Assistant? @relation("UserAssistant", fields: [assistantId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([phone])
  @@index([accountHandle])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ============================================
// TEACHERS
// ============================================
model Teacher {
  id              String    @id // Business ID: T001, T002, ...
  fullName        String    @map("full_name")
  email           String?
  phone           String?
  birthDate       DateTime? @map("birth_date") @db.Date
  university      String?
  highSchool      String?   @map("high_school")
  province        String?
  specialization  String?
  bankAccount     String?   @map("bank_account")
  bankQrLink      String?   @map("bank_qr_link")
  photoUrl        String?   @map("photo_url")
  roles           Json      @default("[]") // ['teacher', 'lesson_plan', 'accountant', ...]
  status          String    @default("active") // active | inactive
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user            User?     @relation("UserTeacher")
  classes         ClassTeacher[]
  sessions        Session[]
  payrolls        Payroll[]
  bonuses         Bonus[]

  @@map("teachers")
}

// ============================================
// CLASSES
// ============================================
model Class {
  id                    String      @id // Business ID: C001, ...
  name                  String
  type                  String
  status                ClassStatus @default(running)
  maxStudents           Int         @default(15) @map("max_students")
  tuitionPerSession     Int         @default(0) @map("tuition_per_session")
  schedule              Json        @default("[]") // [{ day, time }]
  customTeacherAllowances Json      @default("{}") @map("custom_teacher_allowances") // { teacherId: amount }
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  teachers        ClassTeacher[]
  students        StudentClass[]
  sessions        Session[]
  payments        Payment[]
  revenues        Revenue[]

  @@map("classes")
}

// ============================================
// STUDENTS
// ============================================
model Student {
  id             String        @id // Business ID: S001, ...
  fullName       String        @map("full_name")
  email          String?
  school         String?
  province       String?
  birthYear      Int?          @map("birth_year")
  parentName     String?       @map("parent_name")
  parentPhone    String?       @map("parent_phone")
  status         StudentStatus @default(active)
  gender         Gender        @default(male)
  goal           String?
  lastAttendance DateTime?     @map("last_attendance") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user              User?     @relation("UserStudent")
  classes           StudentClass[]
  attendanceRecords Attendance[]
  payments          Payment[]
  walletTransactions WalletTransaction[]

  @@map("students")
}

// ============================================
// CLASS_TEACHERS (Many-to-Many)
// ============================================
model ClassTeacher {
  id             String   @id @default(cuid())
  classId        String   @map("class_id")
  teacherId      String   @map("teacher_id")
  customAllowance Int?    @map("custom_allowance")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId])
  @@index([classId])
  @@index([teacherId])
  @@map("class_teachers")
}

// ============================================
// STUDENT_CLASSES (Many-to-Many)
// ============================================
model StudentClass {
  id        String   @id @default(cuid())
  studentId String   @map("student_id")
  classId   String   @map("class_id")
  startDate DateTime @map("start_date") @db.Date
  status    String   @default("active") // active | inactive
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([studentId])
  @@index([classId])
  @@map("student_classes")
}

// ============================================
// SESSIONS
// ============================================
model Session {
  id                 String             @id @default(cuid())
  classId            String             @map("class_id")
  teacherId          String?            @map("teacher_id")
  date               DateTime           @db.Date
  startTime          DateTime?          @map("start_time") @db.Time
  endTime            DateTime?          @map("end_time") @db.Time
  duration           Decimal            @default(2.0) @db.Decimal(4, 2) // hours
  coefficient        Decimal            @default(1.0) @db.Decimal(3, 1)
  notes              String?
  paymentStatus      SessionPaymentStatus @default(unpaid) @map("payment_status")
  allowanceAmount    Int?               @map("allowance_amount")
  subsidyOriginal    Int?               @map("subsidy_original")
  subsidyModifiedBy  String?            @map("subsidy_modified_by")
  subsidyModifiedAt  DateTime?          @map("subsidy_modified_at") @db.Timestamptz
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     Teacher?     @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  attendance  Attendance[]

  @@index([classId])
  @@index([teacherId])
  @@index([date])
  @@map("sessions")
}

// ============================================
// ATTENDANCE
// ============================================
model Attendance {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  studentId String   @map("student_id")
  present   Boolean  @default(true)
  remark    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("attendance")
}

// ============================================
// PAYMENTS
// ============================================
model Payment {
  id        String        @id @default(cuid())
  studentId String        @map("student_id")
  classId   String?       @map("class_id")
  amount    Int
  status    PaymentStatus @default(pending)
  date      DateTime      @db.Date
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([classId])
  @@map("payments")
}

// ============================================
// PAYROLL
// ============================================
model Payroll {
  id         String   @id @default(cuid())
  teacherId  String   @map("teacher_id")
  month      String   // YYYY-MM
  totalHours Decimal  @default(0) @map("total_hours") @db.Decimal(6, 2)
  totalSessions Int   @default(0) @map("total_sessions")
  baseRate   Int      @default(0) @map("base_rate")
  bonus      Int      @default(0)
  totalPay   Int      @default(0) @map("total_pay")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, month])
  @@index([teacherId])
  @@index([month])
  @@map("payroll")
}

// ============================================
// REVENUE
// ============================================
model Revenue {
  id               String   @id @default(cuid())
  classId          String   @map("class_id")
  month            String   // YYYY-MM
  enrolledCount    Int      @default(0) @map("enrolled_count")
  tuitionPerStudent Int     @default(0) @map("tuition_per_student")
  totalRevenue     Int      @default(0) @map("total_revenue")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, month])
  @@map("revenue")
}

// ============================================
// WALLET TRANSACTIONS
// ============================================
model WalletTransaction {
  id        String                @id @default(cuid())
  studentId String                @map("student_id")
  type      WalletTransactionType
  amount    Int                   @default(0)
  note      String?
  date      DateTime              @default(now()) @db.Date
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("wallet_transactions")
}

// ============================================
// DASHBOARD CACHE
// ============================================
model DashboardCache {
  cacheKey   String            @id @map("cache_key") // e.g. 'dashboard:month:2024-01'
  cacheType  DashboardCacheType @map("cache_type")
  data       Json
  expiresAt  DateTime          @map("expires_at") @db.Timestamptz
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@index([cacheType])
  @@index([expiresAt])
  @@map("dashboard_cache")
}

// ============================================
// COSTS
// ============================================
model Cost {
  id        String   @id @default(cuid())
  month     String   // YYYY-MM
  category  String
  amount    Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("costs")
}

// ============================================
// BONUSES
// ============================================
model Bonus {
  id       String   @id @default(cuid())
  staffId  String   @map("staff_id")
  workType String   @map("work_type") // Gia sư, Giáo án, Kế toán, ...
  amount   Int      @default(0)
  status   String   @default("unpaid") // paid | unpaid | deposit
  note     String?
  month    String   // YYYY-MM
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  staff Teacher @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([month])
  @@index([status])
  @@map("bonuses")
}

// ============================================
// HOME POSTS
// ============================================
model HomePost {
  id          String          @id @default(cuid())
  category    HomePostCategory
  title       String
  content     String
  attachments Json            @default("[]")
  tags        Json            @default("[]")
  badge       String?
  authorId    String?         @map("author_id")
  authorName  String?         @map("author_name")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  @@index([category])
  @@map("home_posts")
}

// ============================================
// CATEGORIES
// ============================================
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("categories")
}

// ============================================
// ASSISTANTS
// ============================================
model Assistant {
  id            String        @id // Business ID: A001, ...
  fullName      String        @map("full_name")
  email         String?
  phone         String?
  assistantType AssistantType @map("assistant_type")
  status        String        @default("active") // active | inactive
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user             User?              @relation("UserAssistant")
  payments         AssistantPayment[]
  tasks            AssistantTask[]
  lessonPlans      LessonPlan[]
  lessonTasks      LessonTask[]
  lessonOutputs    LessonOutput[]

  @@index([assistantType])
  @@map("assistants")
}

// ============================================
// ASSISTANT PAYMENTS
// ============================================
model AssistantPayment {
  id          String   @id @default(cuid())
  assistantId String   @map("assistant_id")
  amount      Int      @default(0)
  status      String   @default("pending") // paid | pending | deposit
  date        DateTime @db.Date
  note        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  assistant Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)

  @@index([assistantId])
  @@index([date])
  @@map("assistant_payments")
}

// ============================================
// ASSISTANT TASKS (Technical assistants)
// ============================================
model AssistantTask {
  id          String   @id @default(cuid())
  assistantId String   @map("assistant_id")
  contest     String?
  problemName String?  @map("problem_name")
  date        DateTime? @db.Date
  status      String   @default("pending") // paid | pending | deposit (payment status)
  link        String?
  note        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  assistant Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)

  @@index([assistantId])
  @@index([date])
  @@map("assistant_tasks")
}

// ============================================
// LESSON PLANS (Legacy)
// ============================================
model LessonPlan {
  id              String         @id @default(cuid())
  assistantId     String?        @map("assistant_id")
  type            LessonPlanType?
  resourceLink    String?        @map("resource_link")
  tag             String?
  level           String?
  lessonName      String?        @map("lesson_name")
  cost            Int            @default(0)
  date            DateTime?      @db.Date
  status          String         @default("pending") // paid | pending | deposit
  contestUploaded String?        @map("contest_uploaded")
  link            String?
  completedBy     String?        @map("completed_by")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  assistant Assistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  @@index([assistantId])
  @@index([type])
  @@map("lesson_plans")
}

// ============================================
// DOCUMENTS
// ============================================
model Document {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String   @map("file_url")
  tags        Json     @default("[]")
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([uploadedBy])
  @@index([createdAt])
  @@map("documents")
}

// ============================================
// LESSON RESOURCES
// ============================================
model LessonResource {
  id           String   @id @default(cuid())
  resourceLink String   @map("resource_link")
  title        String?
  description  String?
  tags         Json     @default("[]")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([createdAt])
  @@map("lesson_resources")
}

// ============================================
// LESSON TASKS
// ============================================
model LessonTask {
  id          String           @id @default(cuid())
  assistantId String?          @map("assistant_id")
  title       String
  description String?
  status      LessonTaskStatus @default(pending)
  priority    LessonTaskPriority @default(medium)
  dueDate     DateTime?        @map("due_date") @db.Date
  createdBy   String?          @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  assistant Assistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  @@index([assistantId])
  @@index([status])
  @@index([dueDate])
  @@map("lesson_tasks")
}

// ============================================
// LESSON OUTPUTS
// ============================================
model LessonOutput {
  id              String   @id @default(cuid())
  tag             String?
  level           String?
  lessonName      String   @map("lesson_name")
  originalTitle   String?  @map("original_title")
  cost            Int      @default(0)
  date            DateTime @db.Date
  status          String   @default("pending") // paid | pending | deposit
  contestUploaded String?  @map("contest_uploaded")
  link            String?
  completedBy     String?  @map("completed_by")
  assistantId     String?  @map("assistant_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  assistant    Assistant?       @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  topicLinks   LessonTopicLink[]

  @@index([date])
  @@index([status])
  @@index([tag])
  @@map("lesson_outputs")
}

// ============================================
// LESSON TOPICS
// ============================================
model LessonTopic {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  level     Int?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  lessonLinks LessonTopicLink[]

  @@index([isDefault])
  @@index([level])
  @@map("lesson_topics")
}

// ============================================
// LESSON TOPIC LINKS (Many-to-Many)
// ============================================
model LessonTopicLink {
  id             String   @id @default(cuid())
  topicId        String   @map("topic_id")
  lessonOutputId String   @map("lesson_output_id")
  orderIndex     Int      @default(0) @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  topic        LessonTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  lessonOutput LessonOutput @relation(fields: [lessonOutputId], references: [id], onDelete: Cascade)

  @@unique([topicId, lessonOutputId])
  @@index([topicId])
  @@index([lessonOutputId])
  @@index([topicId, orderIndex])
  @@map("lesson_topic_links")
}
