model Class {
  id                            String         @id @default(uuid())
  name                          String
  type                          ClassType      @default(basic)
  status                        ClassStatus    @default(running)
  maxStudents                   Int            @default(15) @map("max_students")
  allowancePerSessionPerStudent Int            @default(0) @map("allowance_per_session_per_student")
  maxAllowancePerSession        Int?           @map("max_allowance_per_session")
  scaleAmount                   Int?           @map("scale_amount")
  schedule                      Json           @default("[]")
  studentTuitionPerSession      Int?           @map("student_tuition_per_session")
  tuitionPackageTotal           Int?           @map("tuition_package_total")
  tuitionPackageSession         Int?           @map("tuition_package_session")
  createdAt                     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  surveys                       ClassSurvey[]
  teachers                      ClassTeacher[]
  sessions                      Session[]
  students                      StudentClass[]

  @@map("classes")
}

model ClassTeacher {
  id              String    @id @default(uuid())
  classId         String    @map("class_id")
  teacherId       String    @map("teacher_id")
  customAllowance Int?      @map("custom_allowance")
  status          String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher         StaffInfo @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId])
  @@index([classId])
  @@index([teacherId])
  @@map("class_teachers")
}

model StudentClass {
  id                             String      @id @default(uuid())
  studentId                      String      @map("student_id")
  classId                        String      @map("class_id")
  customStudentTuitionPerSession Int?        @map("custom_student_tuition_per_session")
  customTuitionPackageTotal      Int?        @map("custom_tuition_package_total")
  customTuitionPackageSession    Int?        @map("custom_tuition_package_session")
  totalAttendedSession           Int?        @map("total_attended_session")
  createdAt                      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  class                          Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  student                        StudentInfo @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([classId])
  @@map("student_classes")
}

model Session {
  id                   String       @id @default(uuid())
  teacherId            String       @map("teacher_id")
  classId              String       @map("class_id")
  allowanceAmount      Int?         @map("allowance_amount")
  teacherPaymentStatus String       @default("unpaid") @map("teacher_payment_status")
  date                 DateTime     @db.Date
  startTime            DateTime?    @map("start_time") @db.Time(6)
  endTime              DateTime?    @map("end_time") @db.Time(6)
  coefficient          Decimal      @default(1.0) @db.Decimal(3, 1)
  notes                String?
  tuitionFee           Int?         @map("tuition_fee")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  attendance           Attendance[]
  class                Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher              StaffInfo    @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
  @@index([classId])
  @@index([date])
  @@index([classId, date])
  @@index([teacherId, date])
  @@index([teacherId, teacherPaymentStatus, date])
  @@map("sessions")
}

model Attendance {
  id                        String                     @id @default(uuid())
  sessionId                 String                     @map("session_id")
  studentId                 String                     @map("student_id")
  status                    AttendanceStatus           @default(present)
  notes                     String?
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  customerCareCoef          Decimal?                   @map("customer_care_coef") @db.Decimal(3, 2)
  customerCareStaffId       String?                    @map("customer_care_staff_id")
  customerCarePaymentStatus PaymentStatus?             @map("customer_care_payment_status")
  tuitionFee                Int?                       @map("tuition_fee")
  transactionId             String?                    @unique @map("transaction_id")
  customerCareStaff         StaffInfo?                 @relation(fields: [customerCareStaffId], references: [id])
  session                   Session                    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student                   StudentInfo                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transaction               WalletTransactionsHistory? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("attendance")
}

model CfProblemTutorial {
  id           String   @id @default(uuid())
  contestId    Int      @map("contest_id")
  problemIndex String   @map("problem_index")
  tutorial     String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([contestId, problemIndex])
  @@index([contestId])
  @@map("cf_problem_tutorials")
}
