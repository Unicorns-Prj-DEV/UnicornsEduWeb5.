model ClassSurvey {
  id         String     @id @default(uuid())
  classId    String?    @map("class_id")
  testNumber Int        @map("test_number")
  teacherId  String?    @map("teacher_id")
  reportDate DateTime   @map("report_date") @db.Date
  content    String
  createdAt  DateTime?  @map("created_at") @db.Timestamp(6)
  class      Class?     @relation(fields: [classId], references: [id])
  teacher    StaffInfo? @relation(fields: [teacherId], references: [id])

  @@index([classId])
  @@index([teacherId])
  @@map("class_surveys")
}

model ActionHistory {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  userEmail     String?  @map("user_email")
  entityId      String?  @map("entity_id")
  entityType    String?  @map("entity_type")
  actionType    String?  @map("action_type")
  beforeValue   Json?    @map("before_value")
  afterValue    Json?    @map("after_value")
  changedFields Json?    @map("changed_fields")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  description   String?
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([actionType])
  @@index([createdAt])
  @@map("action_history")
}

model Document {
  id          String  @id @default(uuid())
  title       String
  description String?
  fileUrl     String  @map("file_url")
  tags        Json    @default("[]")
  uploadedBy  String? @map("uploaded_by")

  @@map("documents")
}

model Notification {
  id              String             @id @default(uuid())
  title           String             @db.VarChar(160)
  message         String             @db.Text
  status          NotificationStatus @default(draft)
  version         Int                @default(0)
  pushCount       Int                @default(0) @map("push_count")
  lastPushedAt    DateTime?          @map("last_pushed_at") @db.Timestamptz(6)
  createdByUserId String?            @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       User?              @relation("NotificationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([lastPushedAt])
  @@index([updatedAt])
  @@index([createdByUserId])
  @@map("notifications")
}

model Regulation {
  id                String                @id @default(uuid())
  title             String                @db.VarChar(200)
  description       String?
  content           String                @db.Text
  audiences         RegulationAudience[]  @default([])
  resourceLink      String?               @map("resource_link")
  resourceLinkLabel String?               @map("resource_link_label") @db.VarChar(160)
  createdByUserId   String?               @map("created_by_user_id")
  updatedByUserId   String?               @map("updated_by_user_id")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy         User?                 @relation("RegulationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy         User?                 @relation("RegulationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("regulations")
}
