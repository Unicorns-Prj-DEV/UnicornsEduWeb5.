model StaffLessonTask {
  id                 String        @id @default(uuid())
  staffId            String        @map("staff_id")
  lessonTaskId       String        @map("lesson_task_id")
  allowance          Int           @default(0) @map("allowance")
  staffPaymentStatus PaymentStatus @default(pending) @map("staff_payment_status")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lessonTask         LessonTask    @relation(fields: [lessonTaskId], references: [id], onDelete: Cascade)
  staff              StaffInfo     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, lessonTaskId])
  @@index([staffId])
  @@index([lessonTaskId])
  @@map("staff_lesson_task")
}

model LessonTask {
  id               String             @id @default(uuid())
  title            String?
  description      String?
  status           LessonTaskStatus
  priority         LessonTaskPriority
  dueDate          DateTime?          @map("due_date") @db.Date
  createdBy        String?            @map("created_by")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lessonOutputs    LessonOutput[]
  lessonResources  LessonResource[]
  createdByStaff   StaffInfo?         @relation(fields: [createdBy], references: [id])
  staffLessonTasks StaffLessonTask[]

  @@index([status, dueDate])
  @@index([updatedAt])
  @@map("lesson_task")
}

model LessonResource {
  id           String      @id @default(uuid())
  resourceLink String      @map("resource_link")
  title        String?
  description  String?
  tags         Json        @default("[]")
  createdBy    String?     @map("created_by")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  lessonTaskId String?
  lessonTask   LessonTask? @relation(fields: [lessonTaskId], references: [id])

  @@index([createdAt])
  @@index([updatedAt])
  @@map("lesson_resources")
}

model LessonOutput {
  id              String             @id @default(uuid())
  level           String?
  lessonName      String             @map("lesson_name")
  originalTitle   String?            @map("original_title")
  source          String?
  originalLink    String?            @map("original_link")
  cost            Int                @default(0)
  date            DateTime           @db.Date
  contestUploaded String?            @map("contest_uploaded")
  link            String?
  staffId         String?            @map("staff_id")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tags            Json?              @default("[]")
  status          LessonOutputStatus @default(pending) @map("status")
  lessonTaskId    String?            @map("lesson_task_id")
  lessonTask      LessonTask?        @relation(fields: [lessonTaskId], references: [id])
  staff           StaffInfo?         @relation(fields: [staffId], references: [id])

  @@index([date])
  @@index([lessonTaskId])
  @@index([lessonTaskId, status])
  @@index([lessonTaskId, date])
  @@index([status, date])
  @@index([staffId])
  @@index([staffId, date])
  @@index([level])
  @@index([updatedAt])
  @@map("lesson_outputs")
}
