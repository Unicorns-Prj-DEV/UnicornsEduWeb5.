DATABASE_URL="database-url"
PORT=3001
BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Global HTTP rate limiting (@nestjs/throttler). Các auth endpoint nhạy cảm
# như login/register/forgot-password/reset-password còn có limit chặt hơn trong code.
THROTTLE_DEFAULT_LIMIT=300
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_BLOCK_DURATION_MS=60000

# Nếu deploy sau reverse proxy (Nginx/Render/Fly/Heroku), set TRUST_PROXY=1
# hoặc giá trị phù hợp để throttler nhìn thấy đúng client IP. Local dev để false.
TRUST_PROXY=false

# Dashboard response cache trong bảng dashboard_cache của PostgreSQL.
# Đây là TTL cache phía server cho các read endpoint nặng của admin dashboard.
DASHBOARD_CACHE_DEFAULT_TTL_SECONDS=60

# Backend auth identity cache (in-memory, per-process) để giảm query lặp
# bảng users/staff_info ở JwtStrategy, RolesGuard và /auth/profile.
AUTH_IDENTITY_CACHE_TTL_MS=5000
AUTH_IDENTITY_CACHE_MAX_ENTRIES=2000

# Bắt buộc để gửi email xác thực (đăng ký) và quên mật khẩu. Nếu không cấu hình, đăng ký sẽ trả lỗi 503.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
# Gmail: dùng App Password 16 ký tự, không dùng mật khẩu đăng nhập Google thường.
# Có thể dán dạng "abcd efgh ijkl mnop"; backend sẽ bỏ khoảng trắng khi SMTP_HOST là Gmail.
SMTP_PASS="smtp-pass"
SMTP_SECURE=false
MAIL_FROM="no-reply@example.com"

# Google OAuth (đăng nhập bằng Google). Redirect URI trong Google Console: BACKEND_URL/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# Supabase Storage (avatar + CCCD upload)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

JWT_EMAIL_VERIFY_SECRET="a"
JWT_FORGOT_PASSWORD_SECRET="a"
JWT_ACCESS_SECRET="a"
JWT_REFRESH_SECRET="a"

# Google Calendar Service Account Configuration
# Option 1: Base64 encoded service account JSON key (preferred for deployment)
# Get this from Google Cloud Console: IAM & Admin > Service Accounts > Create Key (JSON)
# Then: base64 -i key.json | pbcopy (or copy output)
GOOGLE_SERVICE_ACCOUNT_KEY="base64-encoded-service-account-json"
# Option 2: Direct path to service account JSON file (for local development)
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH="/path/to/service-account-key.json"
# Calendar ID to use (optional, defaults to service account's primary calendar)
# To find your calendar ID: Google Calendar Settings > Calendar ID
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
# Time zone for calendar events (defaults to Asia/Ho_Chi_Minh)
GOOGLE_TIME_ZONE="Asia/Ho_Chi_Minh"

# SePay — tạo đơn nạp ví học sinh (userapi v2). Lấy token & bank account xid từ bảng điều khiển SePay.
# Khi thiếu token hoặc SEPAY_BANK_ACCOUNT_XID, POST /users/me/student-wallet-sepay-topup-order trả 503.
SEPAY_API_ACCESS_TOKEN=""
SEPAY_BANK_ACCOUNT_XID=""
# Tuỳ chọn: https://userapi.sepay.vn (production) hoặc URL sandbox nếu SePay cấp.
# SEPAY_USERAPI_BASE_URL="https://userapi.sepay.vn"
# Bắt buộc với một số ngân hàng (vd. Sacombank) — xem tài liệu SePay VA prefix.
# SEPAY_VA_PREFIX=""
# Thời sống VA/giữ đơn (giây), mặc định 900 khi không set.
# SEPAY_ORDER_DURATION_SECONDS=900
